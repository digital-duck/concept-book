# concept-book environment configuration
#
# Copy this file to .env and edit the values for your setup:
#   cp example.env .env
#
# All keys use the CB_ prefix. The .env file is gitignored — never commit it.

# ── Content pipeline ───────────────────────────────────────────────────────────

# Absolute path to your local SPL.py repo clone.
# Used by scripts/sync_from_spl.sh to pull graph.yaml files.
CB_SPL_DIR=~/projects/digital-duck/SPL.py

# Path to the public/domains directory (relative to repo root or absolute).
# Generated concept_*.html and book_*.html files live here.
CB_PUBLIC_DOMAINS=./public/domains

# ── LLM backend ────────────────────────────────────────────────────────────────

# LLM used by the /api/generate endpoint (spl3 run build_concept_book.spl).
# Format: <adapter>:<model-id>
#
# Claude CLI (default):
CB_LLM=claude_cli:claude-sonnet-4-6
#
# Ollama (local):
# CB_LLM=ollama:gemma3
#
# OpenRouter:
# CB_LLM=openrouter:anthropic/claude-sonnet-4-6

# Default model shown in the BookPage Pane A / Pane B picker.
# Must match one of the model subfolder names under output/{level}.{lang}/
CB_DEFAULT_MODEL=gemma4

# ── Compare cache ──────────────────────────────────────────────────────────────

# How long a cached /api/compare result is reused before expiring (seconds).
# 0 = never expire.  Override on the Settings page at runtime.
#   86400  = 1 day  (default)
#   604800 = 1 week
#   0      = never expire
CB_COMPARE_CACHE_TTL=86400
